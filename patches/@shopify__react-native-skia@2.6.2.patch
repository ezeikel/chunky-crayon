     sk_sp<SkImage> image;
     if (bounds != nullptr) {
       SkIRect b =
@@ -117,6 +124,18 @@ public:
    Render to a canvas
    */
   bool renderToCanvas(const std::function<void(SkCanvas *)> &cb) override {
+    // (chunkycrayon patch) Guard a null offscreen surface. makeOffscreenSurface
+    // (→ MetalContext::MakeOffscreen, patched) returns nullptr when the backing
+    // surface is 0-dim / mid-relayout / torn down — e.g. a deferred autosave or
+    // progress snapshot firing from a setTimeout after the canvas began tearing
+    // down on navigation. Without this check _surface->getCanvas() dereferences
+    // null and SIGSEGVs on the JS thread (SkSurface::getCanvas, far=0x28). The
+    // MetalContext patch fixed the 0-dim SIGABRT but moved the null one frame
+    // here; this closes it. The caller (RNSkView::makeImageSnapshot) already
+    // handles a failed render as "couldn't create image".
+    if (_surface == nullptr) {
+      return false;
+    }
     cb(_surface->getCanvas());
     return true;
   };
