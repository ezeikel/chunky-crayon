generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  email               String?   @unique // Optional for anonymous mobile users
  name                String?
  emailVerified       DateTime?
  image               String?
  stripeCustomerId    String? // set after Stripe customer creation
  revenuecatUserId    String?   @unique // RevenueCat app_user_id (same as our userId)
  credits             Int       @default(15) // initial credits for new users
  showCommunityImages Boolean   @default(false) // parental control for community gallery
  activeProfileId     String? // Currently selected profile
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  subscriptions        Subscription[]
  creditTransactions   CreditTransaction[]
  coloringImages       ColoringImage[]
  savedArtworks        SavedArtwork[] // User's saved colored artwork
  profiles             Profile[] // Multi-profile support for families
  userStickers         UserSticker[] // Collected stickers
  canvasProgress       CanvasProgress[] // Canvas progress for cross-platform sync
  // Auth.js relations
  accounts             Account[]
  sessions             Session[]
  // Mobile device sessions
  mobileDeviceSessions MobileDeviceSession[]
  // User-linked social accounts (for sharing artwork to TikTok, Pinterest, etc.)
  socialAccounts       UserSocialAccount[]
  // Bundles this user has purchased — entitles them to download/colour the
  // bundle's pages. One row per Stripe checkout, immutable post-creation.
  bundlePurchases      BundlePurchase[]

  // Multi-brand support
  brand Brand @default(CHUNKY_CRAYON)

  // Admin gating for /admin/*. Default USER for everyone; flip to ADMIN
  // either manually or via the ADMIN_EMAILS env var auto-promotion in the
  // NextAuth signIn callback (auth.ts).
  role UserRole @default(USER)

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Platform identification
  platform   SubscriptionPlatform @default(STRIPE)
  externalId String               @unique // Stripe subscription ID or RevenueCat transaction ID

  // Legacy field - keep for backwards compatibility during migration
  stripeSubscriptionId String? @unique

  // Subscription state
  planName      PlanName
  billingPeriod BillingPeriod
  status        SubscriptionStatus

  // Timing
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime
  trialStart         DateTime?
  trialEnd           DateTime?
  cancelledAt        DateTime?

  // Grace period handling
  gracePeriodEnd DateTime?

  // Platform-specific metadata
  storeProductId String? // e.g., "splash_sub_monthly_v1" for RevenueCat
  metadata       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Audit log
  events SubscriptionEvent[]

  @@index([userId])
  @@index([platform, externalId])
  @@map("subscriptions")
}

// Audit log for subscription changes (helps debug cross-platform issues)
model SubscriptionEvent {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  eventType       SubscriptionEventType
  platform        SubscriptionPlatform
  externalEventId String?               @unique // Stripe event ID or RevenueCat event ID

  previousStatus SubscriptionStatus?
  newStatus      SubscriptionStatus?
  previousPlan   PlanName?
  newPlan        PlanName?

  creditsAdded Int   @default(0)
  rawPayload   Json? // Store original webhook payload for debugging

  processedAt DateTime @default(now())

  @@index([subscriptionId])
  @@index([externalEventId])
  @@map("subscription_events")
}

model CreditTransaction {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id])
  amount    Int // positive for credit, negative for usage
  type      CreditTransactionType
  reference String? // Stripe payment intent, etc.
  createdAt DateTime              @default(now())

  @@map("credit_transactions")
}

model ColoringImage {
  id                 String           @id @default(cuid())
  title              String
  description        String
  alt                String
  url                String?
  svgUrl             String?
  qrCodeUrl          String?
  // Bespoke instrumental music generated by ElevenLabs Music API, scene-tailored.
  // Renamed from ambientSoundUrl — old name was misleading, this isn't ambient
  // soundscape but actual scored music with felt piano / music box / etc.
  backgroundMusicUrl String?
  animationUrl       String? // Veo-generated animated video for social media carousels (dormant — kept for future models)
  demoReelUrl        String? // Playwright-recorded product-demo reel (prompt → AI draws → Magic Brush) rendered on the Hetzner worker
  demoReelStoryUrl   String? // 60s trimmed copy of the demo reel for IG/FB Stories (Story max is 60s; our reels are ~69s). Generated by the worker right after Remotion render.
  demoReelCoverUrl   String? // 1080×1080 JPEG cover for the reel — finished colored canvas captured right after the Magic Brush sweep
  demoReelVariant    DemoReelVariant? // V2 only — which input variant this reel renders. Drives the produce-v2 cron's rotation; set by worker on successful render.
  socialPostResults  Json? // Per-platform post outcomes: { instagram: {success, mediaId, caption, postedAt}, facebook: {...}, ... }. Used by /api/social/digest to show accurate auto-posted vs manual flags.
  animationPrompt    String? // Pre-generated Veo 3 prompt based on actual image content
  sourcePrompt       String? // Original input description for deduplication across daily generations
  tags               String[]
  difficulty         Difficulty? // Optional: BEGINNER, INTERMEDIATE, ADVANCED, EXPERT
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  generationType     GenerationType   @default(USER)

  // Streaming-generation lifecycle. Rows are inserted GENERATING by
  // createPendingColoringImage so the destination page can render
  // immediately while the Hetzner worker streams partial frames in.
  // Worker flips to READY on persist completion or FAILED on error.
  // Existing rows default READY so the migration is back-compat.
  status              ColoringImageStatus @default(READY)
  // R2 URL of the latest partial frame from the OpenAI stream. Worker
  // uploads each partial here and calls pg_notify so listeners can
  // re-render. Null once the row hits READY (final url + svgUrl take over).
  streamingPartialUrl String?
  // 0–3, count of partial frames received so far. Drives loader progress UX.
  streamingProgress   Int                 @default(0)
  // Human-readable reason for FAILED rows. Surfaced in the retry UI.
  failureReason       String?
  // In-memory id the worker uses to track this generation. Useful for
  // debugging + cancellation; not part of any API contract.
  workerJobId         String?
  User                User?               @relation(fields: [userId], references: [id])
  userId              String?
  profile             Profile?            @relation(fields: [profileId], references: [id])
  profileId           String? // Which profile created this image
  savedArtworks       SavedArtwork[] // Colored versions saved by users

  // LEGACY: 5x5 grid color map. Modern Magic Brush / Auto-Color use the region
  // store (regionMapUrl + regionsJson) for per-pixel region-accurate reveal.
  // colorMapJson is kept as a fallback for images created before the region-store
  // pipeline existed and never backfilled. Do NOT write to it in new code paths —
  // the worker pipeline (record/region-store.ts) populates the modern fields.
  colorMapJson        String?   @db.Text
  colorMapGeneratedAt DateTime?

  // Region-aware fill points for Magic Fill (replaces grid approach for new images)
  fillPointsJson        String?   @db.Text // JSON with region centroids + AI-assigned colors
  fillPointsGeneratedAt DateTime? // When the fill points were generated

  // Topology SVG — internal watertight version of the line art, traced from
  // the raster with aggressive settings to close all gaps. Used ONLY by
  // region detection + reveal-mask pipeline. Users never see this; the
  // display SVG at svgUrl stays stylistically correct.
  svgTopologyUrl String? // R2 URL of the topology SVG (gap-free version)

  // Pre-computed region store for reveal-mask Magic Brush & palette variants.
  // regionMapUrl points to a gzipped Uint16Array pixel→regionId lookup in R2;
  // regionsJson holds per-region metadata { id, bounds, centroid, pixelCount, label, palettes }.
  regionMapUrl       String? // R2 URL of gzipped Uint16Array (regionMapWidth*regionMapHeight*2 bytes)
  regionMapWidth     Int? // Resolution the region map was computed at
  regionMapHeight    Int?
  regionsJson        String?   @db.Text // JSON array of region metadata + palette variants
  regionsGeneratedAt DateTime? // When the region store was generated

  // AI-colored reference image for Auto Color + Magic Brush (holistic coloring)
  coloredReferenceUrl String? // R2 URL of AI-colored version of the line art

  // Canvas progress for cross-platform sync
  canvasProgress CanvasProgress[]

  // Multi-brand support
  brand Brand @default(CHUNKY_CRAYON)

  // Stable, prefixed key for SYSTEM-purpose images. Convention:
  //   ad:<campaign>       — paid ad landing heroes (e.g. 'ad:trex')
  //   demo-reel           — Playwright-recorded product reel fixtures
  //   onboarding-splash   — future onboarding images
  //   legacy-weekly /     — one-off buckets for retired enum values
  //   legacy-monthly        (historical interest only)
  // Null for USER and DAILY rows. Query by prefix (LIKE 'ad:%') to find
  // all images of a class, or exact match for a specific one.
  purposeKey String?

  // Controls public visibility. USER + DAILY images default true (they
  // show in community galleries, daily pick, etc.). Ad heroes, demo
  // reel fixtures, and onboarding splashes are set false so they never
  // leak into user-facing feeds. Source-independent from generationType
  // — a test seed can be SYSTEM with showInCommunity=true.
  showInCommunity Boolean @default(true)

  // Curated pool for OG images. The /api/cron/regenerate-og cron picks
  // 6 images at random from rows where featuredForOG=true; if fewer
  // than 6 are flagged it falls back to most-recent showInCommunity.
  // Toggle via the /admin/images grid.
  featuredForOG Boolean @default(false)

  // Bundle membership. When set, the page belongs to a paid bundle and is
  // gated by BundlePurchase entitlement — never shown in free galleries.
  // Convention: bundle pages are SYSTEM generationType + purposeKey
  // 'bundle:<slug>' + showInCommunity=false. The bundleId/bundleOrder
  // pair gives ordered access without a join table.
  bundleId    String?
  bundleOrder Int?
  bundle      Bundle? @relation(fields: [bundleId], references: [id])

  @@index([generationType, purposeKey])
  @@index([showInCommunity])
  @@index([featuredForOG])
  @@index([bundleId, bundleOrder])
  // Gallery + list queries filter on status=READY everywhere; this index
  // keeps those plans cheap. The cleanup cron also queries status=GENERATING
  // ordered by createdAt — composite covers both.
  @@index([status, createdAt])
  @@map("coloring_images")
}

// Canvas progress model for cross-platform synchronization
model CanvasProgress {
  id               String    @id @default(cuid())
  userId           String
  coloringImageId  String
  actions          Json // Serialized drawing actions
  canvasWidth      Int? // Canvas width for aspect ratio (optional for backward compatibility)
  canvasHeight     Int? // Canvas height for aspect ratio (optional for backward compatibility)
  previewUrl       String? // URL to progress thumbnail for feed display
  previewUpdatedAt DateTime? // Track when preview was last updated (throttle updates)
  version          Int       @default(1) // For conflict resolution
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  coloringImage ColoringImage @relation(fields: [coloringImageId], references: [id], onDelete: Cascade)

  @@unique([userId, coloringImageId])
  @@index([userId])
  @@index([coloringImageId])
  @@map("canvas_progress")
}

// Auth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Mobile device session - links device IDs to users for app authentication
model MobileDeviceSession {
  id         String   @id @default(cuid())
  deviceId   String   @unique // Unique device identifier from mobile app
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now()) // Last time device made an API call

  @@map("mobile_device_sessions")
}

// Track processed webhook events for idempotency (both Stripe and RevenueCat)
model WebhookEvent {
  id          String               @id // Stripe event ID or RevenueCat event ID
  platform    SubscriptionPlatform
  eventType   String // Event type (e.g., "invoice.payment_succeeded" or "INITIAL_PURCHASE")
  processedAt DateTime             @default(now())

  @@map("webhook_events")
}

// Legacy table - kept for backwards compatibility, will be deprecated
model StripeWebhookEvent {
  id          String   @id // Use Stripe event ID directly
  type        String // Event type (e.g., "invoice.payment_succeeded")
  processedAt DateTime @default(now())

  @@map("stripe_webhook_events")
}

// Profile for multi-child accounts (parents can create profiles for each child)
model Profile {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String // "Emma", "Jack", etc.
  avatarId        String     @default("default") // References avatar SVG
  ageGroup        AgeGroup   @default(CHILD)
  difficulty      Difficulty @default(BEGINNER) // Can be overridden in settings
  isDefault       Boolean    @default(false) // First profile is default
  coloStage       Int        @default(1) // Colo evolution stage (1-6)
  coloAccessories String[]   @default([]) // Unlocked Colo accessories ["astronaut-helmet", "crown"]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  coloringImages    ColoringImage[]
  savedArtworks     SavedArtwork[] // Saved colored artwork for this profile
  userStickers      UserSticker[] // Stickers earned by this profile
  challengeProgress ProfileChallengeProgress[] // Weekly challenge progress

  @@map("profiles")
}

// Saved colored artwork - when users color an image and save it to their gallery
model SavedArtwork {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId       String?
  profile         Profile?      @relation(fields: [profileId], references: [id])
  coloringImageId String
  coloringImage   ColoringImage @relation(fields: [coloringImageId], references: [id])
  title           String? // Optional custom title (defaults to original image title)
  imageUrl        String // URL of the saved colored artwork (uploaded to cloud storage)
  thumbnailUrl    String? // Optional smaller preview for gallery listing
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Shares for this artwork
  shares ArtworkShare[]

  @@map("saved_artworks")
}

// Shareable link for artwork - allows viewing without authentication
model ArtworkShare {
  id        String       @id @default(cuid())
  artworkId String
  artwork   SavedArtwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  shareCode String       @unique // URL-safe random code for sharing
  expiresAt DateTime? // Optional expiration (null = never expires)
  viewCount Int          @default(0)
  isActive  Boolean      @default(true) // Can be deactivated by parent
  createdAt DateTime     @default(now())

  @@map("artwork_shares")
}

// User's collected stickers - unlocked through coloring achievements
model UserSticker {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId  String? // Which profile earned this sticker (optional)
  profile    Profile? @relation(fields: [profileId], references: [id])
  stickerId  String // References sticker ID from catalog (not a foreign key - stickers are static)
  isNew      Boolean  @default(true) // Shows "NEW!" badge until viewed
  unlockedAt DateTime @default(now())

  // Prevent duplicate stickers per user
  @@unique([userId, stickerId])
  @@map("user_stickers")
}

// Weekly challenge schedule - which challenge is active for which week
model WeeklyChallenge {
  id          String   @id @default(cuid())
  challengeId String // References challenge ID from catalog (static)
  startDate   DateTime // When the challenge starts
  endDate     DateTime // When the challenge ends
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Challenge progress for all profiles
  progress ProfileChallengeProgress[]

  // Multi-brand support
  brand Brand @default(CHUNKY_CRAYON)

  @@map("weekly_challenges")
}

// Profile's progress on a weekly challenge
model ProfileChallengeProgress {
  id                String          @id @default(cuid())
  profileId         String
  profile           Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  weeklyChallengeId String
  weeklyChallenge   WeeklyChallenge @relation(fields: [weeklyChallengeId], references: [id], onDelete: Cascade)
  progress          Int             @default(0) // Current progress count
  completed         Boolean         @default(false)
  completedAt       DateTime?
  rewardClaimed     Boolean         @default(false) // Has the reward been given?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // One progress record per profile per challenge
  @@unique([profileId, weeklyChallengeId])
  @@map("profile_challenge_progress")
}

// Store API tokens that need periodic refresh (e.g., Pinterest OAuth tokens)
model ApiToken {
  id           String   @id @default(cuid())
  provider     String   @unique // e.g., "pinterest", "tiktok"
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime // When the access token expires
  scopes       String[] // OAuth scopes granted
  metadata     Json? // Any additional provider-specific data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("api_tokens")
}

// Curated kid-safe stock photos used as input for ImageDemoReel renders.
// Populated via scripts/seed-photo-library.ts; consumed by the worker's
// /publish/image-reel handler which picks a random entry whose lastUsed
// is oldest / null. Stored in R2 under public/photo-library/{category}/.
model PhotoLibraryEntry {
  id        String    @id @default(cuid())
  url       String // R2 URL of the source photo
  category  String // "nature" | "animal" | "object" | "food" | "vehicle" | "person"
  alt       String
  safe      Boolean   @default(true) // false = excluded from rotation (moderation flag)
  lastUsed  DateTime? // null until first use — ORDER BY NULLS FIRST picks unused entries first
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Multi-brand — kept CC-only for now but future-proofed.
  brand Brand @default(CHUNKY_CRAYON)

  @@index([brand, safe, lastUsed])
  @@map("photo_library_entries")
}

// Per-user social account connections (for user-facing sharing to TikTok, Pinterest, etc.)
model UserSocialAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String // "tiktok", "pinterest"
  providerAccountId String // TikTok open_id, Pinterest user ID
  accessToken       String   @db.Text
  refreshToken      String   @db.Text
  expiresAt         DateTime
  scopes            String[]
  displayName       String? // TikTok nickname (shown before posting, required by TikTok review)
  avatarUrl         String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("user_social_accounts")
}

enum Brand {
  CHUNKY_CRAYON
  COLORING_HABITAT
}

enum GenerationType {
  USER // Created by a real user clicking Create in the app.
  DAILY // Daily cron scene. Kept distinct because scheduler, dedup, and content safety care about this category specifically.
  SYSTEM // Everything else programmatic — ads, demo reel fixtures, onboarding splashes, test seeds. Use purposeKey to distinguish.
}

// Lifecycle of a ColoringImage row in the streaming-generation pipeline.
// GENERATING rows are inserted up-front by createPendingColoringImage so
// the user can navigate to /coloring-image/[id] immediately and watch the
// stream paint in. Rows transition to READY when the worker finishes
// persisting (R2 upload, SVG trace, region store kickoff). FAILED rows
// represent generations that errored or got swept by the stale-cleanup
// cron after sitting in GENERATING for >15 min. Existing rows default to
// READY so the migration is back-compat.
enum ColoringImageStatus {
  GENERATING
  READY
  FAILED
}

// Which input variant the demo reel was rendered for. Set by the worker
// after a successful V2 render so the produce-v2 cron can rotate variants
// (read most-recent value, pick next in TEXT → IMAGE → VOICE → TEXT cycle).
enum DemoReelVariant {
  TEXT
  IMAGE
  VOICE
}

enum Difficulty {
  BEGINNER // Simple shapes, big lines - suitable for toddlers/beginners
  INTERMEDIATE // Moderate detail - suitable for kids
  ADVANCED // Detailed designs - suitable for teens/experienced
  EXPERT // Intricate patterns - suitable for adults
}

enum AgeGroup {
  TODDLER // 2-4 years
  CHILD // 5-8 years
  TWEEN // 9-12 years
  TEEN // 13-17 years
  ADULT // 18+
}

enum PlanName {
  SPLASH
  RAINBOW
  SPARKLE
}

enum SubscriptionStatus {
  TRIALING // User is in trial period
  ACTIVE // Subscription is active and paid
  PAST_DUE // Payment failed, in grace period
  CANCELLED // User cancelled, but still has access until period end
  EXPIRED // Subscription ended, no access
  PAUSED // Subscription paused (Play Store feature)
  // Legacy statuses kept for backwards compatibility
  INCOMPLETE
  UNPAID
}

enum CreditTransactionType {
  PURCHASE // user bought credits (one-off or via subscription)
  GENERATION // user spent credits to generate an image
  BONUS // user received bonus credits (promo, referral, etc.)
  REFUND // credits refunded to user
  ADJUSTMENT // manual admin adjustment
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
}

// Premade themed coloring bundles sold as one-off Stripe Products
// (not subscriptions). Each bundle is ~10 pages of cohesive line art with
// a story arc. Pages are stored as ColoringImage rows with bundleId set
// and showInCommunity=false so they never leak into the free gallery.
//
// Listing images (hero, page grids, brand card) are pre-rendered by the
// chunky-crayon-worker listing image generator and stored on R2. URLs
// land here so the product page + Stripe checkout can pull them.
model Bundle {
  id      String @id @default(cuid())
  slug    String @unique // e.g. "dino-dance-party" — used in URLs and R2 paths
  name    String // "Dino Dance Party"
  tagline String // marketing one-liner, used on product page + listing images

  // Number of pages this bundle is supposed to contain. Source of truth is
  // pages.count(); pageCount is denormalised for fast listing queries.
  pageCount Int @default(10)

  // Pricing in pence (GBP). 499 = £4.99. Avoids float rounding bugs and
  // matches Stripe's smallest-currency-unit convention.
  pricePence Int    @default(499)
  currency   String @default("gbp")

  // Stripe linkage — populated by the bundle creation script after the
  // listing images have been generated. One Product per bundle, one Price
  // per Product (no tier variants for now).
  stripeProductId String? @unique
  stripePriceId   String? @unique

  // Pre-rendered listing image URLs (R2). All 1200×1200 JPEGs served via
  // the assets.chunkycrayon.com CDN host.
  listingHeroUrl      String?
  listingPageGrid1Url String?
  listingPageGrid2Url String?
  listingPageGrid3Url String?
  listingBrandCardUrl String?

  // Visibility on the public site. Bundles are drafted with published=false
  // so we can stage them, generate art, render listings, then flip to true
  // when ready to sell. Not the same as Stripe Product activeness — Stripe
  // can be live while published=false (e.g. preview links for friends).
  published   Boolean   @default(false)
  publishedAt DateTime?

  // Multi-brand support — a Bundle is brand-specific (CC kid bundles vs
  // CH adult bundles will have different SKUs even if themes overlap).
  brand Brand @default(CHUNKY_CRAYON)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pages     ColoringImage[]
  purchases BundlePurchase[]

  @@index([brand, published])
  @@map("bundles")
}

// Records that a user has bought access to a Bundle. Acts as the
// entitlement check at fetch time — bundle pages are only readable
// for users with a matching BundlePurchase row.
//
// One row per Stripe checkout. Refunds set refundedAt; we keep the row
// rather than deleting so we can show "previously purchased" history and
// audit refund patterns. Access checks must filter refundedAt IS NULL.
model BundlePurchase {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bundleId String
  bundle   Bundle @relation(fields: [bundleId], references: [id])

  // Stripe identifiers for reconciliation against the Stripe Dashboard
  // and webhook events.
  stripeCheckoutSessionId String  @unique
  stripePaymentIntentId   String?

  // Captured price at purchase time so historical purchases survive
  // future bundle reprice without retroactive change.
  pricePence Int
  currency   String @default("gbp")

  purchasedAt DateTime  @default(now())
  refundedAt  DateTime?

  @@unique([userId, bundleId]) // a user can only own a bundle once
  @@index([userId])
  @@index([bundleId])
  @@map("bundle_purchases")
}

// Platform where the subscription was purchased
enum SubscriptionPlatform {
  STRIPE // Web subscriptions
  REVENUECAT // Mobile subscriptions (App Store / Play Store via RevenueCat)
}

// Event types for subscription audit log
enum SubscriptionEventType {
  TRIAL_STARTED
  SUBSCRIPTION_STARTED
  RENEWAL_SUCCESS
  RENEWAL_FAILED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  CANCELLATION_SCHEDULED // User requested cancellation, still active until period end
  CANCELLED // Subscription actually cancelled/ended
  REACTIVATED // User resubscribed after cancellation
  BILLING_ISSUE_DETECTED // Payment failed
  BILLING_ISSUE_RESOLVED // Payment recovered
  GRACE_PERIOD_STARTED
  GRACE_PERIOD_EXPIRED
  REFUNDED
  TRANSFERRED // RevenueCat: subscription transferred to another user
  EXPIRED
}

// ContentReel — researched social-media reels (stats / facts / tips / myth-busts)
// rendered by the worker's Remotion compositions. Replaces the in-memory
// Stat fixtures used during the Phase 0 spike. See
// ~/.claude/plans/content-reels.md for the full schema rationale.
//
// One row = one reel = one daily post. The publish cron picks today's row
// by rotating kind (stat→fact→tip→myth) and selecting the oldest fact-checked,
// not-posted-in-30-days candidate within that kind.
model ContentReel {
  id String @id @default(cuid())

  // Discriminant — drives reveal-beat treatment in the reel template AND
  // fact-check rules at publish time. Must align with ContentReelKind in
  // apps/chunky-crayon-worker/src/video/content-reel/shared/types.ts.
  kind ContentReelKind

  // Voice-friendly declarative line for the reel hook beat.
  hook        String @db.Text
  // Voice-friendly declarative line for the payoff/reveal narration.
  payoff      String @db.Text
  // The dramatic reveal block — interpretation depends on kind:
  //   stat: "7+ hrs" | "-15%"            (numeric)
  //   fact: "Brain regions involved"     (short phrase)
  //   tip:  "Color before bedtime"       (action phrase)
  //   myth: "False" | "True"             (verdict)
  centerBlock String

  // Question-shaped string for the Satori cover JPEG. Generated by Claude
  // at write-time per kind; falls back to `hook` if missing. Cached here
  // because regenerating per render would burn Claude credits and drift.
  coverTeaser String? @db.Text

  // Source — required for stat/fact/myth at publish time, nullable so
  // tip rows (no citation needed) can persist. Publish gate enforces
  // the per-kind requirement.
  sourceTitle String?
  sourceUrl   String?

  // Drives default template selection (shock/warm/quiet). Override is
  // allowed when the category-default mapping doesn't fit a specific item.
  category         ContentReelCategory
  templateOverride ContentReelTemplate?

  // Per-word caption tracks for ElevenLabs-timed voice clips.
  // CaptionToken[] shape — see types.ts. Kept as Json so ElevenLabs's
  // response can be persisted without a joined table.
  hookTokens   Json?
  payoffTokens Json?

  // Perplexity Sonar verification state. Mandatory for stat/fact/myth
  // BEFORE publish; optional for tip. Re-checked weekly by the
  // fact-check cron — items with factCheckedAt > 180d old get re-verified
  // and may be downgraded if newer research contradicts the claim.
  factCheckedAt       DateTime?
  factCheckConfidence FactCheckConfidence?
  factCheckNotes      String?              @db.Text

  // Scheduling state. Set by the publish cron when a row is selected
  // for that day's slot. Used by the dedup-window query: "give me
  // candidates not posted in the last 30d." Null until first publish.
  postedAt          DateTime?
  // Per-platform post outcomes — same shape as ColoringImage.socialPostResults.
  // Useful for the morning Posting Brief email (which platform did this go to,
  // did any retries fire, what's the ig/fb media id).
  socialPostResults Json?

  // Multi-brand support — defaults to CHUNKY_CRAYON. Coloring Habitat
  // gets its own catalogue when CH starts shipping content reels; same
  // schema, different rows.
  brand Brand @default(CHUNKY_CRAYON)

  // R2 URLs for the rendered artefacts. Worker writes these on
  // /jobs/content-reel/publish completion; null until rendered.
  reelUrl  String?
  coverUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hot query: publish cron picks "give me the oldest factCheckedAt where
  // confidence=high, kind=K, brand=B, postedAt<30d-ago-or-null" — composite
  // index keeps that plan cheap as the catalogue grows.
  @@index([kind, brand, factCheckConfidence, postedAt])
  // Fact-check cron: "find rows where factCheckedAt < 180d-ago to re-check"
  @@index([factCheckedAt])
  @@map("content_reels")
}

enum ContentReelKind {
  STAT
  FACT
  TIP
  MYTH
}

enum ContentReelTemplate {
  SHOCK
  WARM
  QUIET
}

enum ContentReelCategory {
  SCREEN_TIME
  ATTENTION
  ANXIETY
  FINE_MOTOR
  CREATIVITY
  FAMILY_BONDING
  PARENTING_TIP
  BRAIN_DEVELOPMENT
  SLEEP
  COMMON_MISCONCEPTION
}

enum FactCheckConfidence {
  HIGH
  MEDIUM
  LOW
}
