{
  "name": "@one-colored-pixel/coloring-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./image-quality": {
      "import": "./dist/image-quality.js",
      "require": "./dist/image-quality.js",
      "types": "./dist/image-quality.d.ts"
    },
    "./scene": {
      "import": "./dist/scene/index.js",
      "require": "./dist/scene/index.js",
      "types": "./dist/scene/index.d.ts"
    },
    "./gallery": {
      "import": "./dist/gallery/index.js",
      "require": "./dist/gallery/index.js",
      "types": "./dist/gallery/index.d.ts"
    },
    "./characters": {
      "import": "./dist/characters/index.js",
      "require": "./dist/characters/index.js",
      "types": "./dist/characters/index.d.ts"
    },
    "./organic": {
      "import": "./dist/organic/index.js",
      "require": "./dist/organic/index.js",
      "types": "./dist/organic/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf .turbo node_modules dist",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:related": "vitest related --run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.51",
    "@ai-sdk/google": "^3.0.35",
    "@ai-sdk/openai": "^3.0.38",
    "@ai-sdk/perplexity": "^3.0.20",
    "@ai-sdk/replicate": "^2.0.21",
    "@one-colored-pixel/canvas": "workspace:^",
    "@one-colored-pixel/storage": "workspace:*",
    "@posthog/ai": "^7.16.0",
    "@resvg/resvg-js": "^2.6.2",
    "ai": "^6.0.106",
    "openai": "^6.33.0",
    "oslllo-potrace": "^4.0.0",
    "qrcode": "^1.5.3",
    "sharp": "^0.34.1",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.2"
  }
}
