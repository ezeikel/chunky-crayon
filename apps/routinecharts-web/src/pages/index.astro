---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Routine Charts — Free Printable Routine Charts for Kids">
  <main class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      Build a routine chart your kid will actually follow.
    </h1>
    <p class="text-lg text-slate-600 mb-8">
      Drag, drop, print. No signup. No email. Free forever.
    </p>
    <a
      href="#builder"
      class="inline-block bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-3 rounded-lg"
    >
      Build my chart
    </a>
    <section id="builder" class="mt-16">
      <p class="text-slate-500 italic">Chart builder coming next.</p>
    </section>
  </main>
</BaseLayout>
