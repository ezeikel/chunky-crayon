---
// PostHog + Vercel Analytics — included once via BaseLayout.
// Init + tracking listeners live in @one-colored-pixel/satellite-shared.
// initAnalytics tags every event with `app: <slug>` for cross-site funnels
// in CC's shared PostHog project (110135). cc-link-tracking auto-fires
// cc_cta_click on any outbound chunkycrayon.com click; blog-view-tracking
// fires blog_post_view on posts.
//
// The slug is passed via a data attribute (NOT define:vars): Astro only
// bundles/processes a plain <script>, and `define:vars` forces is:inline
// which breaks `import` ("Cannot use import statement outside a module").
import { siteConfig } from "@/site.config";
---

<meta data-site-slug={siteConfig.slug} />

<script>
  import { initAnalytics } from "@one-colored-pixel/satellite-shared/analytics";
  import "@one-colored-pixel/satellite-shared/analytics/cc-link-tracking";
  import "@one-colored-pixel/satellite-shared/analytics/blog-view-tracking";

  const slug =
    document
      .querySelector("meta[data-site-slug]")
      ?.getAttribute("data-site-slug") ?? "";
  initAnalytics(slug);
</script>
