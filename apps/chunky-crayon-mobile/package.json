    "react-native-worklets": "~0.8.3",
    "sonner-native": "^0.25.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "^10",
