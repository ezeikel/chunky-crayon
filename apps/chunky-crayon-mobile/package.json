{
  "name": "@one-colored-pixel/chunky-crayon-mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "clean": "git clean -xdf .expo node_modules",
    "start": "expo start",
    "dev": "expo start --ios",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "ios": "expo run:ios --no-build-cache",
    "android": "expo run:android --no-build-cache",
    "build:ios": "pnpm prebuild:ios && pnpm ios",
    "build:android": "pnpm prebuild:android && pnpm android",
    "build": "expo export",
    "eas:build:local": "eas build --profile development --local",
    "eas:build:local:ios": "eas build --platform ios --profile preview --local",
    "eas:build:local:android": "eas build --platform android --profile preview --local",
    "eas:build:development": "eas build --profile development",
    "eas:build:development:android": "eas build --platform android --profile development",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:build:preview:ios:local": "eas build --profile preview --platform ios --local",
    "eas:build:preview:android:local": "eas build --profile preview --platform android --local",
    "eas:build:production": "eas build --profile production",
    "eas:release:ios": "eas build --profile production --platform ios --auto-submit",
    "eas:release:android": "eas build --profile production --platform android --auto-submit",
    "eas:submit:beta": "eas submit --profile beta",
    "eas:submit:production": "eas submit --profile production",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "check-types": "tsc --noEmit",
    "env:pull": "eas env:pull --environment development"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.3",
    "@fortawesome/fontawesome-svg-core": "^6.7.1",
    "@fortawesome/free-solid-svg-icons": "^6.7.1",
    "@fortawesome/pro-light-svg-icons": "^6.7.1",
    "@fortawesome/pro-regular-svg-icons": "^6.7.1",
    "@fortawesome/pro-solid-svg-icons": "^6.7.1",
    "@fortawesome/react-native-fontawesome": "^0.3.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@jamsch/expo-speech-recognition": "^0.2.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/native": "^7.0.9",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.4.18",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "axios": "^1.7.8",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "expo": "~55.0.5",
    "expo-apple-authentication": "~55.0.8",
    "expo-application": "^55.0.8",
    "expo-audio": "~55.0.8",
    "expo-blur": "^55.0.8",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image-picker": "~55.0.11",
    "expo-insights": "~55.0.10",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-media-library": "^55.0.9",
    "expo-notifications": "~55.0.11",
    "expo-print": "~55.0.8",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-updates": "~55.0.12",
    "expo-web-browser": "~55.0.9",
    "lottie-react-native": "~7.3.1",
    "nativewind": "5.0.0-preview.2",
    "prettier": "^3.4.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css": "^3.0.4",
    "react-native-fbsdk-next": "^13.4.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-html-to-pdf": "^0.12.0",
    "react-native-purchases": "^9.6.12",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "~0.7.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.61.6",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^18.3.0",
    "eslint-config-expo": "~55.0.0",
    "expo-mcp": "~0.2.1",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "postcss": "^8",
    "react-test-renderer": "18.3.1",
    "tailwindcss": "^4",
    "typescript": "~5.9.3"
  },
  "private": true
}
