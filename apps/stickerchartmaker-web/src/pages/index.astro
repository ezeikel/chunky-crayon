---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import { StickerChart } from "../components/StickerChart/StickerChart";
---

<BaseLayout title="Sticker Chart Maker | Free Printable Sticker & Reward Charts for Kids">
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12 md:py-16">
    <div class="text-center mb-8 sm:mb-10 md:mb-14">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-slate-900 mb-3 sm:mb-4">
        Make a sticker chart your kid will actually fill.
      </h1>
      <p class="text-base sm:text-lg text-slate-600 max-w-xl mx-auto">
        Set a goal, pick the reward, print. No signup. No email. Free forever.
      </p>
    </div>

    <div class="bg-slate-50 border border-slate-200 rounded-2xl sm:rounded-3xl p-3 sm:p-5 md:p-8 shadow-sm">
      <StickerChart client:load />
    </div>

    <section class="mt-16 grid md:grid-cols-3 gap-6 text-sm">
      <div>
        <div class="text-2xl mb-2">🎯</div>
        <h3 class="font-semibold text-slate-900 mb-1">Set one clear goal</h3>
        <p class="text-slate-600">
          One behavior, one chart. Stay in bed, use the potty, kind hands.
        </p>
      </div>
      <div>
        <div class="text-2xl mb-2">🖨️</div>
        <h3 class="font-semibold text-slate-900 mb-1">Print at home</h3>
        <p class="text-slate-600">
          A4 / Letter, fits any printer. Includes a coloring page reward.
        </p>
      </div>
      <div>
        <div class="text-2xl mb-2">⭐</div>
        <h3 class="font-semibold text-slate-900 mb-1">Add a sticker a day</h3>
        <p class="text-slate-600">
          Fill every box, earn the reward. Stick it where they can see it.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
