{
  "name": "one-colored-pixel",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@one-colored-pixel/chunky-crayon-web",
    "build:mobile": "turbo run build --filter=@one-colored-pixel/chunky-crayon-mobile",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@one-colored-pixel/chunky-crayon-web",
    "dev:mobile": "turbo run dev --filter=@one-colored-pixel/chunky-crayon-mobile",
    "dev:habitat": "turbo run dev --filter=@one-colored-pixel/coloring-habitat-web",
    "build:habitat": "turbo run build --filter=@one-colored-pixel/coloring-habitat-web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:web": "turbo run test --filter=@one-colored-pixel/chunky-crayon-web",
    "test:e2e": "turbo run test:e2e --filter=@one-colored-pixel/chunky-crayon-web",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma"
  },
  "lint-staged": {
    "apps/chunky-crayon-web/**/*.{ts,tsx}": [
      "cd apps/chunky-crayon-web && tsc --noEmit",
      "cd apps/chunky-crayon-web && next lint --fix --file"
    ],
    "**/*.+(js|jsx|json|ts|tsx|html|md)": [
      "prettier --ignore-path .gitignore --write"
    ],
    "**/!(e2e)/*.{js,jsx,ts,tsx}": [
      "vitest related --run --passWithNoTests --config vitest.config.mts"
    ],
    "**/prisma/schema.prisma": [
      "pnpm exec prisma format --schema"
    ]
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^16.0.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.8.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3",
      "lightningcss": "1.30.1"
    }
  }
}
